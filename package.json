{
  "name": "@voidifydao/sdk",
  "version": "2.0.0",
  "description": "Voidify client SDK and CLI for interacting with the Anchor voidify program suite (browser + Node).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "voidify": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "npm run build && node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@switchboard-xyz/common": "^5.8.1",
    "@switchboard-xyz/on-demand": "^3.10.1",
    "better-sqlite3": "^12.9.0",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "circomlibjs": "^0.1.7",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "cors": "^2.8.6",
    "dexie": "^4.4.2",
    "express": "^5.2.1",
    "ffjavascript": "^0.3.1",
    "fixed-merkle-tree": "^0.7.3",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "snarkjs": "^0.7.6",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bn.js": "^5.2.0",
    "@types/circomlibjs": "^0.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/snarkjs": "^0.7.9",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "solana",
    "anchor",
    "voidify",
    "cli"
  ],
  "author": "",
  "license": "MIT"
}
